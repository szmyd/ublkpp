 extern int ublksrv_ctrl_stop_dev(struct ublksrv_ctrl_dev *dev);

+/**
+ * Quiesce the specified ublk device. Halts I/O and transitions to
+ * UBLK_S_DEV_QUIESCED without deleting /dev/ublkbN, allowing a new server
+ * to recover via ublksrv_ctrl_start_recovery / ublksrv_ctrl_end_recovery.
+ * Requires UBLK_F_USER_RECOVERY | UBLK_F_QUIESCE flags on the device.
+ *
+ * @param dev the ublksrv control device instance
+ */
+extern int ublksrv_ctrl_quiesce_dev(struct ublksrv_ctrl_dev *dev);
+
 /**
  * Dump this ublk device
