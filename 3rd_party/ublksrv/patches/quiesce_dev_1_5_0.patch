diff --git a/lib/ublksrv_cmd.c b/lib/ublksrv_cmd.c
index 25ddbbe..90a2694 100644
--- a/lib/ublksrv_cmd.c
+++ b/lib/ublksrv_cmd.c
@@ -472,6 +472,19 @@ int ublksrv_ctrl_stop_dev(struct ublksrv_ctrl_dev *dev)
 	return ret;
 }

+int ublksrv_ctrl_quiesce_dev(struct ublksrv_ctrl_dev *dev)
+{
+	struct ublksrv_ctrl_cmd_data data = {
+		.cmd_op	= UBLK_U_CMD_QUIESCE_DEV,
+	};
+	int ret;
+
+	ublk_un_privileged_prep_data(dev, data);
+
+	ret = __ublksrv_ctrl_cmd(dev, &data);
+	return ret;
+}
